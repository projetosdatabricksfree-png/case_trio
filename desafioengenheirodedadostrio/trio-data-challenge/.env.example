# =============================================================================
#  Trio Data Challenge — Variáveis de Ambiente (template)
#
#  Uso:   cp .env.example .env
#
#  ⚠️  NUNCA commite o arquivo `.env` (ele está no .gitignore).
#  Estes valores são defaults de DESENVOLVIMENTO. Em produção (AWS), as
#  credenciais devem vir de um cofre de segredos (Docker secrets / AWS SSM /
#  Secrets Manager) — ver docs/adr/ADR-0001-image-versioning.md e o runbook.
# =============================================================================

# Prefixo estável para containers, volumes e rede (reprodutibilidade).
COMPOSE_PROJECT_NAME=trio

# TimescaleDB & PostgreSQL Legado (mesmas credenciais nos dois Postgres)
POSTGRES_USER=trio
POSTGRES_PASSWORD=trio2024

# ClickHouse
CLICKHOUSE_USER=trio
CLICKHOUSE_PASSWORD=trio2024

# Carga do ClickHouse (Sprint 04 · make seed-ch). Default modesto p/ rodar rápido;
# suba CH_SEED_TX (ex.: 100000000) p/ validar a query Pix sub-segundo no headline.
CH_SEED_TX=5000000
CH_SEED_BATCH=1000000
