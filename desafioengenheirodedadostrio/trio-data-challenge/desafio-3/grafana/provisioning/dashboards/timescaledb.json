{
  "uid": "trio-timescaledb",
  "title": "Trio · TimescaleDB",
  "tags": ["trio", "sprint-06", "timescaledb"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Conexões ativas",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS conexoes FROM pg_stat_activity WHERE datname = 'trio_transactions'"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "textMode": "auto", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "max_connections",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT setting::int AS max_conn FROM pg_settings WHERE name = 'max_connections'"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "textMode": "auto", "graphMode": "none" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tamanho da hypertable",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT hypertable_size('transactions') AS bytes"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "textMode": "auto", "graphMode": "none" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Chunks comprimidos / total",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) FILTER (WHERE is_compressed) AS comprimidos, count(*) AS total FROM timescaledb_information.chunks WHERE hypertable_name = 'transactions'"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "textMode": "auto", "graphMode": "none" }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Compressão (antes / depois / ratio)",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT pg_size_pretty(before_compression_total_bytes) AS antes, pg_size_pretty(after_compression_total_bytes) AS depois, round(before_compression_total_bytes::numeric / NULLIF(after_compression_total_bytes, 0), 1) AS ratio, number_compressed_chunks AS chunks_comprimidos FROM hypertable_compression_stats('transactions')"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Continuous aggregates",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT view_name, materialized_only, compression_enabled FROM timescaledb_information.continuous_aggregates ORDER BY view_name"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Jobs (compressão / retenção / refresh)",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 11 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT j.job_id, j.proc_name, j.hypertable_name, j.scheduled, s.last_run_status, s.last_successful_finish, s.total_failures FROM timescaledb_information.jobs j LEFT JOIN timescaledb_information.job_stats s USING (job_id) WHERE j.job_id >= 1000 ORDER BY j.job_id"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Queries em execução (mais longas)",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT pid, state, round(extract(epoch FROM now() - query_start)::numeric, 1) AS duracao_s, left(query, 90) AS query FROM pg_stat_activity WHERE datname = 'trio_transactions' AND state = 'active' AND query NOT ILIKE '%pg_stat_activity%' ORDER BY duracao_s DESC NULLS LAST LIMIT 10"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    }
  ]
}
